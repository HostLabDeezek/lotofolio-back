{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./",
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*",
        "prisma.config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "generated"
    ]
}