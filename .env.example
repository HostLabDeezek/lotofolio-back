# Base de données PostgreSQL (format : postgresql://user:password@host:port/dbname)
DATABASE_URL=

# Secret de signature des JWT — minimum 32 caractères
# Astuce : générer avec `openssl rand -hex 32`
JWT_SECRET=

# Durée de validité des tokens (ex: 7d, 24h, 60m)
JWT_EXPIRES_IN=

# Port d'écoute du serveur HTTP
PORT=

# Environnement d'exécution (development | production | test)
NODE_ENV=

# Origines autorisées par CORS (séparées par des virgules si plusieurs)
# Ex: http://localhost:4200,https://lotofolio.fr
FRONTEND_URL=

# Token secret pour les tâches cron internes (générer avec `openssl rand -hex 32`) pour la création des tirages
INTERNAL_CRON_SECRET=

# Marge de cutoff en minutes : on refuse de jouer un tirage à moins de N minutes de sa date (défaut : 6)
CUTOFF_MARGIN_MINUTES=
